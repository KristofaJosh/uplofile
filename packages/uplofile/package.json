{
  "name": "uplofile",
  "version": "2.3.2",
  "description": "Composable file‑upload components for React.",
  "license": "MIT",
  "author": "Chris Josh <KristofaJosh>",
  "repository": {
    "type": "git",
    "url": "https://github.com/KristofaJosh/uplofile.git"
  },
  "homepage": "https://uplofile.kristofajosh.dev",
  "keywords": [
    "react",
    "react-component",
    "upload",
    "uploads",
    "file",
    "file upload",
    "file uploader",
    "multipart form",
    "uploader",
    "dropzone",
    "drag-and-drop",
    "composable",
    "form"
  ],
  "type": "module",
  "main": "./dist/web.mjs",
  "types": "./dist/web.d.ts",
  "exports": {
    ".": {
      "types": "./dist/web.d.ts",
      "default": "./dist/web.mjs"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "react-native": "./dist/native.mjs",
      "default": "./dist/native.mjs"
    }
  },
  "react-native": {
    "./native": "./dist/native.mjs"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bunchee --dts --external react,react-dom,react-native,react-native-document-picker --format esm",
    "clean": "rm -rf dist",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.2.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.1",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "bunchee": "6.6.0",
    "jsdom": "^29.1.1",
    "prettier": "3.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "4.0.0",
    "typescript": "5.5.4",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "react": ">=16.0.0",
    "react-dom": ">=16.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native-document-picker": {
      "optional": true
    }
  }
}
