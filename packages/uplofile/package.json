{
  "name": "uplofile",
  "version": "3.0.1",
  "description": "Composable file‑upload components for React.",
  "license": "MIT",
  "author": "Chris Josh <KristofaJosh>",
  "repository": {
    "type": "git",
    "url": "https://github.com/KristofaJosh/uplofile.git"
  },
  "homepage": "https://uplofile.kristofajosh.dev",
  "keywords": [
    "react",
    "react-component",
    "upload",
    "uploads",
    "file",
    "file upload",
    "file uploader",
    "multipart form",
    "uploader",
    "dropzone",
    "drag-and-drop",
    "composable",
    "form"
  ],
  "type": "module",
  "main": "./dist/web.mjs",
  "types": "./dist/web.d.ts",
  "exports": {
    ".": {
      "types": "./dist/web.d.ts",
      "default": "./dist/web.mjs"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "react-native": "./dist/native.mjs",
      "default": "./dist/native.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bunchee --dts --external react,react-dom,react-native,@react-native-documents/picker --format esm",
    "clean": "rm -rf dist",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "bunchee": "6.10.0",
    "jsdom": "^29.1.1",
    "prettier": "3.8.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "peerDependencies": {
    "react": ">=16.0.0",
    "react-dom": ">=16.0.0",
    "react-native": "*",
    "@react-native-documents/picker": "*"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "@react-native-documents/picker": {
      "optional": true
    }
  }
}
